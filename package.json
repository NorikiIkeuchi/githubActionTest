{
  "name": "github-actions-playground",
  "version": "1.0.0",
  "description": "GitHub Actions の学習用アプリ",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js'",
    "build:docs": "node scripts/generate-docs.js"
  },
  "keywords": ["github-actions", "learning"],
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "supertest": "^7.0.0"
  }
}
